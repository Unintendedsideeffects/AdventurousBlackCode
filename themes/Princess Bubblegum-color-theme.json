{
	"name": "Princess Bubblegum Theme",
	"type": "light",
	"colors": {
		"editor.background": "#FFF0F8",
		"editorGutter.background": "#FFE6F2",
		"editor.foreground": "#4D1A3D",
		"activityBar.background": "#FFE6F2",
		"tab.activeBackground": "#FF69B4",
		"tab.activeForeground": "#FFFFFF",
		"tab.activeBorder": "#D946A8",
		"tab.activeBorderTop": "#FF69B4",
		"tab.inactiveBackground": "#FFE6F2",
		"tab.inactiveForeground": "#7D3B6D",
		"editorLineNumber.activeForeground": "#D946A8",
		"editorLineNumber.foreground": "#C879AF",
		"statusBar.background": "#FF69B4",
		"statusBar.foreground": "#FFFFFF",
		"statusBar.debuggingBackground": "#9B30FF",
		"statusBar.noFolderBackground": "#FFB6D9",
		"panel.background": "#FFF0F8",
		"sideBar.background": "#FFE6F2",
		"sideBarSectionHeader.background": "#FF69B4",
		"sideBarSectionHeader.foreground": "#FFFFFF",
		"activityBarBadge.background": "#D946A8",
		"activityBarBadge.foreground": "#FFFFFF",
		"sideBarTitle.foreground": "#7D3B6D",
		"titleBar.activeBackground": "#FF69B4",
		"titleBar.activeForeground": "#FFFFFF",
		"titleBar.inactiveBackground": "#FFE6F2",
		"titleBar.inactiveForeground": "#7D3B6D",
		"scrollbarSlider.background": "#FF69B4AA",
		"scrollbarSlider.hoverBackground": "#D946A8CC",
		"editorWidget.background": "#FFF0F8",
		"editorWidget.border": "#D946A8",
		"input.background": "#FFFFFF",
		"input.border": "#FF69B4",
		"button.background": "#FF69B4",
		"button.foreground": "#FFFFFF",
		"editor.selectionBackground": "#FF69B466",
		"editor.inactiveSelectionBackground": "#FF69B433",
		"editor.selectionHighlightBackground": "#FF69B420",
		"editor.wordHighlightBackground": "#D946A833",
		"editor.wordHighlightStrongBackground": "#D946A866",
		"editorCursor.foreground": "#D946A8",
		"editorBracketMatch.border": "#D946A8"
	},
	"tokenColors": [
		{
			"settings": {
				"foreground": "#4D1A3D",
				"background": "#FFF0F8"
			}
		},
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#B565A7"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"string constant.other.placeholder"
			],
			"settings": {
				"foreground": "#C71585"
			}
		},
		{
			"name": "Colors",
			"scope": [
				"constant.other.color"
			],
			"settings": {
				"foreground": "#4D1A3D"
			}
		},
		{
			"name": "Invalid",
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#DC143C"
			}
		},
		{
			"name": "Keyword, Storage",
			"scope": [
				"keyword",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#E91E8C"
			}
		},
		{
			"name": "Operator, Misc",
			"scope": [
				"constant.other.color",
				"punctuation",
				"meta.tag",
				"punctuation.definition.tag",
				"punctuation.separator.inheritance.php",
				"punctuation.definition.tag.html",
				"punctuation.definition.tag.begin.html",
				"punctuation.definition.tag.end.html",
				"punctuation.section.embedded",
				"keyword.other.template",
				"keyword.other.substitution"
			],
			"settings": {
				"foreground": "#7D3B6D"
			}
		},
		{
			"name": "Control",
			"scope": [
				"keyword.control"
			],
			"settings": {
				"foreground": "#E91E8C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Tag",
			"scope": [
				"entity.name.tag",
				"meta.tag.sgml",
				"markup.deleted.git_gutter"
			],
			"settings": {
				"foreground": "#E91E8C"
			}
		},
		{
			"name": "Function, Special Method",
			"scope": [
				"entity.name.function",
				"variable.function",
				"support.function",
				"keyword.other.special-method"
			],
			"settings": {
				"foreground": "#D946A8"
			}
		},
		{
			"name": "Meta function",
			"scope": [
				"meta.function-call"
			],
			"settings": {
				"foreground": "#4D1A3D",
				"fontStyle": "normal"
			}
		},
		{
			"name": "Meta function generic",
			"scope": [
				"meta.function-call.generic"
			],
			"settings": {
				"foreground": "#D946A8",
				"fontStyle": "normal"
			}
		},
		{
			"name": "Operator",
			"scope": [
				"keyword.operator.assignment",
				"keyword.operator.comparison",
				"keyword.operator.arithmetic"
			],
			"settings": {
				"foreground": "#FF1493",
				"fontStyle": "normal"
			}
		},
		{
			"name": "Function parameters",
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#7D3B6D",
				"fontStyle": "normal"
			}
		},
		{
			"name": "Block Level Variables",
			"scope": [
				"meta.block variable.other"
			],
			"settings": {
				"foreground": "#C71585"
			}
		},
		{
			"name": "Other Variable, String Link",
			"scope": [
				"support.other.variable",
				"string.other.link"
			],
			"settings": {
				"foreground": "#C71585"
			}
		},
		{
			"name": "Constant, Function Argument, Tag Attribute, Embedded",
			"scope": [
				"support.constant",
				"constant.character",
				"constant.escape",
				"keyword.other.unit",
				"keyword.other"
			],
			"settings": {
				"foreground": "#9B30FF"
			}
		},
		{
			"name": "Number",
			"scope": [
				"constant.numeric"
			],
			"settings": {
				"foreground": "#C71585",
				"fontStyle": "normal"
			}
		},
		{
			"name": "Constant",
			"scope": [
				"constant.language"
			],
			"settings": {
				"foreground": "#E91E8C",
				"fontStyle": "italic"
			}
		},
		{
			"name": "String, Symbols, Inherited Class, Markup Heading",
			"scope": [
				"string",
				"constant.other.symbol",
				"constant.other.key",
				"entity.other.inherited-class",
				"markup.heading",
				"markup.inserted.git_gutter",
				"meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
			],
			"settings": {
				"fontStyle": "normal",
				"foreground": "#DA70D6"
			}
		},
		{
			"name": "Class, Support",
			"scope": [
				"entity.name",
				"support.type",
				"support.class",
				"support.orther.namespace.use.php",
				"meta.use.php",
				"support.other.namespace.php",
				"markup.changed.git_gutter",
				"support.type.sys-types"
			],
			"settings": {
				"foreground": "#BA55D3"
			}
		},
		{
			"name": "Entity Types",
			"scope": [
				"support.type"
			],
			"settings": {
				"foreground": "#BA55D3"
			}
		},
		{
			"name": "CSS Class and Support",
			"scope": [
				"source.css support.type.property-name",
				"source.sass support.type.property-name",
				"source.scss support.type.property-name",
				"source.less support.type.property-name",
				"source.stylus support.type.property-name",
				"source.postcss support.type.property-name"
			],
			"settings": {
				"foreground": "#C71585"
			}
		},
		{
			"name": "Attributes",
			"scope": [
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#FF69B4"
			}
		},
		{
			"name": "HTML Attributes",
			"scope": [
				"text.html.basic entity.other.attribute-name.html",
				"text.html.basic entity.other.attribute-name"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#FF69B4"
			}
		},
		{
			"name": "CSS Classes",
			"scope": [
				"entity.other.attribute-name.class"
			],
			"settings": {
				"foreground": "#FF69B4"
			}
		},
		{
			"name": "Inserted",
			"scope": [
				"markup.inserted",
				"markup.inserted.diff",
				"meta.diff.header.git",
				"meta.diff.header.from-file"
			],
			"settings": {
				"foreground": "#32CD32",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Deleted",
			"scope": [
				"markup.deleted",
				"markup.deleted.diff"
			],
			"settings": {
				"foreground": "#DC143C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Changed",
			"scope": [
				"markup.changed",
				"markup.changed.diff"
			],
			"settings": {
				"foreground": "#E91E8C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Diff Comments",
			"scope": [
				"comment.line.diff",
				"meta.diff.comment",
				"punctuation.definition.comment.diff"
			],
			"settings": {
				"foreground": "#B565A7",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Regular Expressions",
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#9B30FF"
			}
		},
		{
			"name": "Escape Characters",
			"scope": [
				"constant.character.escape"
			],
			"settings": {
				"foreground": "#FF1493"
			}
		},
		{
			"name": "URL",
			"scope": [
				"*url*",
				"*link*",
				"*uri*"
			],
			"settings": {
				"fontStyle": "underline"
			}
		}
	]
}
